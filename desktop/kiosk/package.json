{
  "name": "orda-kiosk",
  "version": "0.2.1",
  "private": true,
  "main": "main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,magenta \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "build": "vite build",
    "dist": "vite build && electron-builder --win",
    "start": "electron .",
    "setup": "electron . --setup"
  },
  "build": {
    "appId": "kz.ordaops.kiosk",
    "productName": "Orda Kiosk",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "main/**/*",
      "preload.js",
      "scripts/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "padash00",
      "repo": "OrdaKiosk"
    },
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "include": "scripts/installer.nsh"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.454.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.9",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "electron": "41.2.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.9",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  }
}
