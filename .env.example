NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=https://your-app-domain.vercel.app

# Optional fallback for server-side admin client if NEXT_PUBLIC_SUPABASE_URL is not used there
SUPABASE_URL=https://your-project.supabase.co
APP_URL=https://your-app-domain.vercel.app

# Required for admin auth actions: staff invites, account creation, privileged writes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required for Telegram notifications from tasks, shifts and reports
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Optional: used by AI analysis action
GEMINI_API_KEY=your-gemini-api-key
