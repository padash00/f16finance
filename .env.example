NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=https://your-app-domain.vercel.app

# Optional fallback for server-side admin client if NEXT_PUBLIC_SUPABASE_URL is not used there
SUPABASE_URL=https://your-project.supabase.co
APP_URL=https://your-app-domain.vercel.app

# Required for admin auth actions: staff invites, account creation, privileged writes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# REQUIRED: super admin email list (comma-separated). If not set, super-admin access is disabled.
ADMIN_EMAILS=your-admin@email.com

# Required for Telegram notifications from tasks, shifts and reports
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Admin chat ID for deficit shift alerts (can be personal chat or group)
TELEGRAM_ADMIN_CHAT_ID=your-chat-id

# REQUIRED for Telegram webhook verification — без этой переменной webhook полностью заблокирован
TELEGRAM_WEBHOOK_SECRET=your-telegram-webhook-secret

# Optional: used by AI analysis action
GEMINI_API_KEY=your-gemini-api-key

# Public site lead form via SMTP/Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Orda Control Site <your-email@gmail.com>"
CONTACT_LEAD_TO=padash00@gmail.com
