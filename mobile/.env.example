# Скопируй в .env и заполни (значения = те же, что в Vercel у веб-проекта).
# Все переменные с префиксом EXPO_PUBLIC_ доступны в приложении на этапе сборки.

EXPO_PUBLIC_SUPABASE_URL=https://<твой-проект>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<NEXT_PUBLIC_SUPABASE_ANON_KEY>

# База API (прод). Локалхост с телефона не виден — используй прод или туннель.
EXPO_PUBLIC_API_BASE_URL=https://ordaops.kz
