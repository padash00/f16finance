{
  "expo": {
    "name": "Orda",
    "slug": "orda-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "orda",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#070809",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "kz.ordaops.mobile",
      "userInterfaceStyle": "dark",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Для быстрого и безопасного входа в Orda по Face ID."
      }
    },
    "android": {
      "package": "kz.ordaops.mobile",
      "userInterfaceStyle": "dark",
      "adaptiveIcon": {
        "backgroundColor": "#070809"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-local-authentication",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#070809",
          "resizeMode": "contain"
        }
      ]
    ]
  }
}
